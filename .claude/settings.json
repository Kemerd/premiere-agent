{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync*)",
      "Bash(uv pip *)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(uv lock*)",
      "Bash(uv tool *)",
      "Bash(uv venv*)",
      "Bash(uv export*)",
      "Bash(uv tree*)",
      "Bash(pip install *)",
      "Bash(pip install --upgrade *)",
      "Bash(pip install -r *)",
      "Bash(pip install -e *)",
      "Bash(pip uninstall *)",
      "Bash(pip list*)",
      "Bash(pip show *)",
      "Bash(pip freeze*)",
      "Bash(pip check*)",
      "Bash(python -m pip install *)",
      "Bash(python -m pip uninstall *)",
      "Bash(python -m pip list*)",
      "Bash(python -m pip show *)",
      "Bash(python -m pip freeze*)",
      "Bash(python -m venv *)",
      "Bash(pipx install *)",
      "Bash(pipx upgrade *)",
      "Bash(pipx list*)",
      "Bash(conda install *)",
      "Bash(conda env *)",
      "Bash(conda list*)",
      "Bash(python helpers/*)",
      "Bash(python -m helpers.*)",
      "Bash(python -c *)",
      "Bash(python --version)",
      "Bash(ffprobe*)",
      "Bash(ffmpeg*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git ls-files*)",
      "Bash(ls*)",
      "Bash(dir*)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(type *)",
      "Bash(Get-Content *)",
      "Bash(Get-ChildItem*)",
      "Bash(Test-Path *)",
      "Bash(Select-String *)",
      "Bash(Measure-Object*)",
      "Bash(Where-Object *)",
      "Bash(Select-Object *)",
      "Bash(echo *)",
      "Bash(Write-Output *)",
      "Bash(mkdir *)",
      "Bash(New-Item *)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(Remove-Item -Recurse -Force*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fdx*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(iwr * | iex*)",
      "Bash(Invoke-Expression*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git tag*)",
      "Bash(git reset*)",
      "Bash(npm install --global*)",
      "Bash(npm install -g*)",
      "Bash(pip install --user*)",
      "Bash(pip install --break-system-packages*)"
    ]
  }
}
